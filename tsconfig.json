{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "target": "ES2018",
    "lib": [
      "DOM",
      "ES2018"
    ],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "vitest"
    ]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "esbuild.config.mjs",
    "vitest.config.ts"
  ]
}
