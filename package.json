{
  "name": "science-input-helper",
  "version": "0.7.2",
  "description": "Input helper for Chinese science notes: chemical formulas, reaction arrows, units, Greek letters, Roman numerals, and lightweight math structures.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs watch",
    "build": "tsc -noEmit && node esbuild.config.mjs production",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "latex",
    "chemistry",
    "physics",
    "science-notes"
  ],
  "author": "XinXi Xu",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "^6.38.6",
    "@types/node": "^24.10.1",
    "@typescript-eslint/parser": "^8.60.1",
    "builtin-modules": "^5.0.0",
    "esbuild": "^0.27.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
